# Application under test (required)
BASE_URL=https://staging.example.com

# Test user credentials (required if app needs login)
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# Multi-role credentials (optional — only if testing role-based access)
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# VIEWER_EMAIL=
# VIEWER_PASSWORD=

# CI flag (set automatically in CI pipelines — do not set locally)
# CI=true
